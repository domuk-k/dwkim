# blog — 환경변수 템플릿
# 복사: cp .env.example .env.local
# ⚠️  .env* 는 gitignore 대상 (Astro 권장: .env.local).

# ─── Vercel Analytics ────────────────────────────────────────────
# Vercel 배포 시 자동 주입됨. 로컬 개발 시 선택적.
# VERCEL_ANALYTICS_ID=

# ─── Build (선택) ────────────────────────────────────────────────
# Cogni SSOT 경로 override (기본: ~/.cogni)
# COGNI_PATH=

# ─── Site (astro.config.mjs 에서 참조 가능) ──────────────────────
# PUBLIC_SITE_URL=https://dwkim.dev

# 실질적으로 블로그는 거의 env 불필요 — 정적 사이트.
# 추가 키 필요 시 src/content.config.ts 또는 astro.config.mjs 확인.
