# dwkim CLI — 로컬/개발용 환경변수 템플릿
# 복사: cp .env.example .env
# .env 는 gitignore 대상. 값은 커밋하지 말 것.

# ─── Runtime (optional) ──────────────────────────────────────────
# persona-api 기본 URL. 자체 운영 시 변경.
# 기본값: https://persona-api.fly.dev
DWKIM_API_URL=

# ─── Development (optional) ──────────────────────────────────────
# 디버그 로그 활성화 (개발 시)
# DEBUG=dwkim:*
