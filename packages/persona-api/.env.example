# persona-api — 환경변수 템플릿
# 복사: cp .env.example .env
# ⚠️  .env 는 gitignore 대상. 실제 값은 절대 커밋 금지.
# 프로덕션 시크릿은 `fly secrets set KEY=value` 로만 관리.

# ─── Server ──────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development   # production | development | test
LOG_LEVEL=info         # debug | info | warn | error

# ─── LLM Provider (필수: 최소 1개) ───────────────────────────────
# OpenRouter 권장 (여러 모델 단일 키)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
LLM_GENERATION_MODEL=   # 사용자 응답용 (예: anthropic/claude-sonnet-4)
LLM_UTILITY_MODEL=      # 내부 처리용 (예: google/gemini-2.5-flash-lite)

# 대체 프로바이더 (선택)
GOOGLE_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# ─── Rate Limiting ───────────────────────────────────────────────
RATE_LIMIT_MAX=50
RATE_LIMIT_WINDOW_MS=60000

# ─── RAG ─────────────────────────────────────────────────────────
MAX_SEARCH_RESULTS=10
CONTEXT_WINDOW=4000
ENABLE_SEU=true
SYSTEM_PROMPT=

# ─── Conversation Store (선택) ───────────────────────────────────
# 미설정 시 in-memory fallback (프로세스 재시작 시 유실)
# 프로덕션은 TLS 필수: rediss:// 스킴 사용
REDIS_URL=

# ─── Observability (선택) ────────────────────────────────────────
LOGTAIL_TOKEN=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ─── Security ────────────────────────────────────────────────────
# 관리자 API (sync 등) Bearer 토큰. openssl rand -hex 32 로 생성 권장
ADMIN_API_KEY=

# CORS — 쉼표로 구분. 미설정 시 제한 없음 (개발용)
ALLOWED_ORIGINS=

# ─── Misc ────────────────────────────────────────────────────────
API_HOST=localhost:3000
MOCK_MODE=             # 'true' 시 LLM 호출 없이 테스트
DISCORD_WEBHOOK_URL=   # 에러 알림용 (선택)

# ─── Legacy / Removed ────────────────────────────────────────────
# DATABASE_URL — 현재 env.ts 스키마에 없음. Neon 직접 연결 없이 BM25 로컬 인덱스 사용.
