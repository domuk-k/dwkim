{
  "name": "persona-api",
  "version": "2.0.0",
  "description": "Personalized RAG+LLM Chatbot API",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "bun dist/index.js",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "type-check": "tsc --noEmit",
    "init-data": "bun scripts/initData.ts",
    "init-neon": "bun scripts/initNeonData.ts",
    "init-neon:clean": "bun scripts/initNeonData.ts --clean",
    "init-neon:test": "bun scripts/initNeonData.ts --test",
    "init-neon:retrieval": "bun scripts/initNeonData.ts --retrieval",
    "build:index": "bun scripts/buildSearchIndex.ts",
    "manage": "bun scripts/manageData.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:rebuild": "docker-compose down && docker-compose up -d --build"
  },
  "dependencies": {
    "@ai-sdk/langchain": "^2.0.54",
    "@anthropic-ai/sdk": "^0.55.0",
    "@changesets/cli": "^2.29.4",
    "@elysiajs/bearer": "^1.4.2",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "@huggingface/transformers": "^3.8.1",
    "@langchain/anthropic": "^1.3.2",
    "@langchain/community": "^1.0.0",
    "@langchain/core": "^1.0.0",
    "@langchain/google-genai": "^1.0.0",
    "@langchain/langgraph": "^1.0.0",
    "@langchain/langgraph-checkpoint": "^1.0.0",
    "@langchain/openai": "^1.2.0",
    "@langfuse/client": "^4.6.1",
    "@langfuse/langchain": "^4.6.1",
    "@langfuse/otel": "^4.6.1",
    "@langfuse/tracing": "^4.6.1",
    "@logtail/pino": "^0.5.7",
    "@neondatabase/serverless": "^0.10.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-node": "^2.5.1",
    "ai": "^6.0.49",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.22",
    "gray-matter": "^4.0.3",
    "lru-cache": "^11.2.4",
    "openai": "^6.15.0",
    "pg": "^8.13.0",
    "pino": "^10.1.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.10.0",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
